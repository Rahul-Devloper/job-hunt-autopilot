{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: debug server-side",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "env": { "NODE_OPTIONS": "--inspect" }
    },
    {
      "name": "Next.js: attach to router (port 9230)",
      "type": "node",
      "request": "attach",
      "port": 9230,
      "skipFiles": ["<node_internals>/**"],
      "sourceMaps": true,
      "restart": true
    }
  ]
}
